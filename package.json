{
  "name": "eventra-bihar-repository",
  "private": true,
  "scripts": {
    "install:all": "npm --prefix frontend install && npm --prefix backend install",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "start:frontend": "npm --prefix frontend run start",
    "start:backend": "npm --prefix backend run start",
    "db:migrate": "npm --prefix backend run db:migrate",
    "create:admin": "npm --prefix backend run create:admin"
  }
}
