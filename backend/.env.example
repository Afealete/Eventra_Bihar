# Runtime
NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=

# Comma-separated browser origins permitted to call the API.
FRONTEND_ORIGIN=http://localhost:3000

# Eventra application session signing keys. Use unique values of at least 32
# characters in production.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Optional legacy fallback. Prefer the two secrets above for all new setups.
JWT_SECRET=

# Optional shared parent domain for session cookies in production, for example
# .example.com. Leave blank for local development.
COOKIE_DOMAIN=

# Firebase Admin service-account fields. Keep FIREBASE_PRIVATE_KEY quoted and
# retain literal \n separators when using an environment-variable dashboard.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Cloudinary image upload credentials.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Used only by the explicit create-admin script.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
